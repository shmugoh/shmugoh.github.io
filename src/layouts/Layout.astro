---
import Head from "./Head.astro";
import {NavBar} from '@/components/NavBar'

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<Head title={title} />
    <div class="flex container justify-between items-center min-h-screen">
        <div class="flex flex-wrap items-center gap-2.5 w-full min-h-screen justify-center prose">
            <slot/>
        </div>
        
        <div class="flex flex-col">
            <NavBar client:load />
        </div>
    </div>
</Head>